{
  "redirects": [
    {
      "source": "/comparador",
      "destination": "/comparador.html",
      "permanent": true
    },
    {
      "source": "/mattebox",
      "destination": "/mattebox.html",
      "permanent": true
    },
    {
      "source": "/gabo3dprint",
      "destination": "/gabo3dprint.html",
      "permanent": true
    },
    {
      "source": "/talleres",
      "destination": "/talleres.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://*.mercadopago.com https://*.mlstatic.com; media-src 'self'; connect-src 'self' https://*.mercadopago.com https://*.upstash.io;"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
